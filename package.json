{
  "name": "findout",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "node scripts/with-local-env.mjs next dev",
    "build": "prisma generate && next build",
    "build:local": "node scripts/with-local-env.mjs prisma generate && node scripts/with-local-env.mjs next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:push:local": "node scripts/with-local-env.mjs prisma db push",
    "db:local:up": "docker compose up -d findout-db",
    "db:local:down": "docker compose down"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "14.2.15",
    "next-auth": "5.0.0-beta.22",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
