# ------------------------------------------------------------------
# FindOut - environment variables
# Copy to .env.local and fill in. The app can boot without these, but
# login, persistence, and occupancy data require the values below.
# ------------------------------------------------------------------

# Local file-backed dev storage. Use this when you do not have Postgres locally.
LOCAL_DEV_DB="file"

# Postgres connection string (Supabase / Neon / local). Required outside local
# file-backed dev mode.
# Docker Postgres default:
# DATABASE_URL="postgresql://findout:findout@localhost:54329/findout?schema=public"
DATABASE_URL="postgresql://user:password@localhost:5432/findout?schema=public"

# Auth.js - generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"

# Public base URL of your app, used for the OAuth redirect.
# Local:  http://localhost:3000
# Deploy: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Hack Club Auth OAuth client.
# Register an app at https://auth.hackclub.com and set the redirect URI to:
#   {NEXTAUTH_URL}/api/auth/callback/hackclub
HACKCLUB_CLIENT_ID=""
HACKCLUB_CLIENT_SECRET=""

# OIDC scopes. `slack_id` is needed for occupancy identity and Cachet avatars.
# `email` lets people search by email.
HACKCLUB_SCOPE="openid profile email slack_id"

# Slack membership gate. The bot token needs `groups:read`, and the app must be
# invited to the private #soup-base channel.
SLACK_BOT_TOKEN="xoxb-..."
SOUP_BASE_CHANNEL_ID="G..."
