# ------------------------------------------------------------------
# FindOut — environment variables
# Copy to .env.local and fill in. The app also runs WITHOUT any of
# these (it falls back to bundled mock occupancy data for the demo).
# ------------------------------------------------------------------

# Postgres connection string (Supabase / Neon / local). Optional for
# the read-only demo, REQUIRED to let people save their own room.
DATABASE_URL="postgresql://user:password@localhost:5432/findout?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"

# Public base URL of your app (used for the OAuth redirect).
# Local:  http://localhost:3000
# Deploy: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Hack Club Auth OAuth client.
# Register an app at https://auth.hackclub.com and set the redirect URI to:
#   {NEXTAUTH_URL}/api/auth/callback/hackclub
HACKCLUB_CLIENT_ID=""
HACKCLUB_CLIENT_SECRET=""

# OIDC scopes. `slack_id` is a Hack Club custom scope needed for the slack_id
# claim (used for avatars via Cachet). `email` gives searchable emails.
HACKCLUB_SCOPE="openid profile email slack_id"
